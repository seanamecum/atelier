# Mira — environment template.
# Copy to .env.local and fill in. Nothing here is required to run the prototype
# (it works fully in-memory); these wire the production integrations documented
# in ARCHITECTURE.md. .env.local is gitignored — never commit real secrets.

# ── API base ───────────────────────────────────────────────────────────────
# Blank = same-origin (web). Native iOS/Android builds set this to the deployed
# API origin so they reuse the exact same /api/v1 backend.
NEXT_PUBLIC_API_BASE_URL=

# ── Database (PostgreSQL + Prisma) ─────────────────────────────────────────
# e.g. Supabase / Neon connection string. Used by prisma/schema.prisma.
DATABASE_URL=postgresql://user:password@host:5432/mira?schema=public

# ── Auth (pick one provider) ───────────────────────────────────────────────
# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# …or Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI services ────────────────────────────────────────────────────────────
# LLM that backs POST /api/v1/stylist (drop-in for the deterministic engine).
ANTHROPIC_API_KEY=
# Image / virtual-try-on model endpoint (replaces the vector figure renderer).
TRYON_MODEL_URL=

# ── Storage (user photos, closet images) ───────────────────────────────────
# Cloudinary
CLOUDINARY_URL=
# …or AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ── Payments (Stripe) ──────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Analytics ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=
